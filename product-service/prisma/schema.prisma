generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model Category {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  description String?
  products    Product[]
}

model Product {
  id          Int            @id @default(autoincrement())
  name        String
  description String?
  imageUrl    String?
  price       Float
  stock       Int            @default(0)
  categoryId  Int
  category    Category       @relation(fields: [categoryId], references: [id])
  reviews     Review[]
  inventory   InventoryLog[]
}

model InventoryLog {
  id        Int      @id @default(autoincrement())
  productId Int
  product   Product  @relation(fields: [productId], references: [id])
  change    Int      // e.g., -5, +10
  reason    String
  createdAt DateTime @default(now())
}

model Review {
  id        Int      @id @default(autoincrement())
  productId Int
  product   Product  @relation(fields: [productId], references: [id])
  userId    Int
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
}
